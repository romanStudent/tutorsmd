model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.VarChar(255)
  name            String    @db.VarChar(255)
  surname         String    @db.VarChar(255)
  username        String    @unique @db.VarChar(40)
  passwordHash    String?   @db.VarChar(255) @map("password_hash")
  timezone        String    @default("UTC") @db.VarChar(64)
  languageCode    String    @default("ru") @db.VarChar(10) @map("language_code")
  avatarUrl       String?   @db.Text @map("avatar_url")
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  createdAt       DateTime  @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt       DateTime  @updatedAt @db.Timestamptz() @map("updated_at")

  supportMessages SupportMessage[] @relation("SupportMessageSender")
  supportTickets    SupportTicket[]
  sentMessages      SupportMessage[] @relation("MessageSender")

  userRoles          UserRole[]
  refreshToken       RefreshToken[]
  oauthProvider      OAuthProvider[]
  emailVerifications EmailVerification?
  passwordResets     PasswordReset?
  feedbacks          Feedback[]
  emailChange        EmailChange?
  client             Client?
  tutor              Tutor?
  admin              Admin?

  @@map("users")
}

enum Role {
  client
  tutor
  gast
  admin
}


model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  role      Role
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid @map("user_id")
  tokenHash  String    @unique @db.VarChar(255) @map("token_hash")
  deviceInfo String?   @db.VarChar(255) @map("device_info")
  expiresAt  DateTime  @db.Timestamptz() @map("expires_at")
  revokedAt  DateTime? @db.Timestamptz() @map("revoked_at")
  createdAt  DateTime  @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)


  @@index([userId])   // userId нужен для "выйти со всех устройств"
  @@map("refresh_tokens")
}

model OAuthProvider {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  provider   String   @db.VarChar(50)
  providerId String   @db.VarChar(255) @map("provider_id")
  email      String?  @db.VarChar(255)
  createdAt  DateTime @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([provider, providerId])
  @@map("oauth_providers")
}

model EmailVerification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid @map("user_id")
  linkHash  String   @unique @db.Text @map("link_hash")
  expiresAt DateTime @db.Timestamptz() @map("expires_at")
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model EmailChange {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid @map("user_id")
  newEmail  String   @unique @db.VarChar(255) @map("new_email")
  linkHash  String   @unique @db.Text @map("link_hash")
  expiresAt DateTime @db.Timestamptz() @map("expires_at")
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_changes")
}

model PasswordReset {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid @map("user_id")
  linkHash  String   @unique @db.VarChar(64) @map("link_hash")
  expiresAt DateTime @db.Timestamptz() @map("expires_at")
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}
