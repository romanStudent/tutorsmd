model Review {
  id        String   @id @default(uuid()) @db.Uuid
  lessonId  String   @db.Uuid @map("lesson_id")
  clientId  String   @db.Uuid @map("client_id")
  tutorId   String   @db.Uuid @map("tutor_id")
  rating    Int      @db.SmallInt  // 1-5
  comment   String?  @db.Text
  tutorResponse      String?   @db.Text @map("tutor_response")
  tutorRespondedAt   DateTime? @db.Timestamptz() @map("tutor_responded_at")
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz() @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id])
  client Client @relation(fields: [clientId], references: [id])
  tutor  Tutor  @relation(fields: [tutorId], references: [id])

  @@unique([clientId, tutorId])
  @@index([tutorId, rating])   // Covering Index(Index Only Scan). AVG(rating)
  @@map("reviews")
}