enum AppealStatus {
  open
  resolved
  rejected
}

model Appeal {
  id          String       @id @default(uuid()) @db.Uuid 
  lessonId    String       @db.Uuid @map("lesson_id")
  clientId    String?      @db.Uuid @map("client_id")  // NULL если от тьютора
  tutorId     String?      @db.Uuid @map("tutor_id")  // NULL если от клиента
  status      AppealStatus @default(open)
  text        String       @db.Text
  resolvedBy  String?       @db.Uuid @map("resolved_by")  // FK -> admin. NULL
  resolvedAt  DateTime?    @db.Timestamptz() @map("resolved_at")
  expiresAt   DateTime?    @db.Timestamptz() @map("expires_at")
  createdAt   DateTime     @default(now()) @db.Timestamptz() @map("created_at")

  lesson Lesson  @relation(fields: [lessonId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
  tutor  Tutor?  @relation(fields: [tutorId], references: [id])

  @@index([lessonId])   // все апелляции по уроку
  @@index([clientId])   // все апелляции клиента
  @@index([tutorId])    // все апелляции тьютора
  @@index([status])     // все открытые апелляции (для админа)
  @@map("appeals")
}