model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  text      String   @db.Text
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}