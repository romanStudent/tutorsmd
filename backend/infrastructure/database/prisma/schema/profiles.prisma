enum ApprovalStatus {
  pending
  approved
  rejected
}

model Client {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @unique @db.Uuid
  avatarUrl    String?  @db.Text
  createdAt    DateTime @default(now()) @db.Timestamptz()
  updatedAt    DateTime @updatedAt @db.Timestamptz()

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  reviews   Review[]
  materials LessonMaterial[]
  regularSchedules RegularSchedule[]

  @@map("clients")
}

model Tutor {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @unique @db.Uuid
  avatarUrl       String?        @db.Text
  fulldescribeDe  String?        @db.Text
  fulldescribeRu  String?        @db.Text
  highlightDe     String?        @db.Text
  highlightRu     String?        @db.Text
  hourlyRate      Decimal?       @db.Decimal(10, 2)
  ratingAvg       Decimal        @default(0) @db.Decimal(3, 2)
  ratingCount     Int            @default(0)
  approvalStatus  ApprovalStatus @default(pending)
  approvedAt      DateTime?      @db.Timestamptz()
  approvedBy      String?        @db.Uuid
  createdAt       DateTime       @default(now()) @db.Timestamptz()
  updatedAt       DateTime       @updatedAt @db.Timestamptz()

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableSubjects AvailableSubject[]
  availableSlots    AvailableSlot[]
  lessons          Lesson[]
  reviews          Review[]
  regularSchedules RegularSchedule[]
  materials        LessonMaterial[]

  @@map("tutors")
}

model Admin {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}