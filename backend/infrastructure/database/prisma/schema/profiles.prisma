enum ApprovalStatus {
  pending
  submitted
  under_review
  approved
  rejected

  @@map("approval_status")
}

model Client {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid @map("user_id")
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamptz() @map("updated_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessons          Lesson[]
  reviews          Review[]
  materials        LessonMaterial[]  @relation("ClientMaterial")
  regularSchedules RegularSchedule[]
  clientNotes      LessonClientNote[]
  appeals          Appeal[]

  quizAttempts     QuizAttempt[]

  @@map("clients")
}

model Tutor {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @unique @db.Uuid @map("user_id")
  fulldescribeDe String?        @db.Text @map("fulldescribe_de")
  fulldescribeRu String?        @db.Text @map("fulldescribe_ru")
  highlightDe    String?        @db.Text @map("highlight_de")
  highlightRu    String?        @db.Text @map("highlight_ru")
  nameDe         String?        @db.VarChar(100) @map("name_de")
  nameRu         String?        @db.VarChar(100) @map("name_ru")
  surnameDe      String?        @db.VarChar(100) @map("surname_de")
  surnameRu      String?        @db.VarChar(100) @map("surname_ru")
  hourlyRate     Decimal?       @db.Decimal(10, 2) @map("hourly_rate")
  ratingAvg      Decimal        @default(0) @db.Decimal(3, 2) @map("rating_avg")
  ratingCount    Int            @default(0) @map("rating_count")
  approvalStatus ApprovalStatus @default(pending) @map("approval_status")
  approvedAt     DateTime?      @db.Timestamptz() @map("approved_at")
  approvedBy     String?        @db.Uuid @map("approved_by")
  rejectionReason String?       @db.Text @map("rejection_reason")
  createdAt      DateTime       @default(now()) @db.Timestamptz() @map("created_at")
  updatedAt      DateTime       @updatedAt @db.Timestamptz() @map("updated_at")

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorSubjects       TutorSubject[]
  availableSlots      AvailableSlot[]
  lessons             Lesson[]
  reviews             Review[]
  regularSchedules    RegularSchedule[]
  materials           LessonMaterial[]    @relation("TutorMaterial")
  tutorReports        LessonTutorReport[]
  appeals             Appeal[]
  quizzes             Quiz[]
  quizAnswerFeedbacks QuizAnswerFeedback[]

  @@map("tutors")
}

model Admin {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid @map("user_id")
  createdAt DateTime @default(now()) @db.Timestamptz() @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}