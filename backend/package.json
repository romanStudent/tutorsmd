{
  "name": "backed-tutors",
  "module": "index.ts",
  "type": "commonjs",
  "prisma": {
    "schema": "./infrastructure/database/prisma/schema"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.19.21",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "compression": "^1.8.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "helmet": "^8.2.0",
    "nodemon": "^3.1.7",
    "prisma": "6.18.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec \"ts-node --project tsconfig.json\" index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "migrate:test": "cross-env NODE_OPTIONS=--max-old-space-size=4096 DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tutorsmd_test prisma db push --force-reset --skip-generate",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test vitest --config vitest.config.ts",
    "test:run": "cross-env NODE_ENV=test vitest run --config vitest.config.ts",
    "test:watch": "cross-env NODE_ENV=test vitest --watch",
    "test:coverage": "cross-env NODE_ENV=test vitest run --coverage --config vitest.config.ts",
    "test:unit": "cross-env NODE_ENV=test vitest run tests/unit --config vitest.config.ts",
    "test:integration": "cross-env NODE_ENV=test vitest run tests/integration --config vitest.config.ts",
    "test:ci": "cross-env NODE_ENV=test vitest run --coverage --config vitest.config.ts",
    "check": "npm run db:generate && npm run typecheck && npm run test:ci && npm run build"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@prisma/client": "6.18.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "async-local-storage": "^2.3.1",
    "bullmq": "^5.77.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dayjs": "^1.11.13",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "sanitize-filename": "^1.6.3",
    "socket.io": "^4.8.1",
    "uuid": "^10.0.0",
    "uuidv7": "^1.2.1",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  }
}
