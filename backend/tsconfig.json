{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": [
    "./**/*.ts",
    "./types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "infrastructure/database/prisma/migrations/v0__create_users.ts",
    "infrastructure/database/prisma/migrations/v1__create_user_roles.ts",
    "infrastructure/database/prisma/migrations/v2__migrate_clients_to_users.ts",
    "infrastructure/database/prisma/migrations/v3__migrate_tutors_to_users.ts",
    "infrastructure/database/prisma/migrations/v4__remove_duplicate_fields_from_clients.ts",
    "infrastructure/database/prisma/migrations/v5__remove-duplicate_from_tutors.ts",
    "infrastructure/database/prisma/migrations/v6__rebuild_bookings.ts",
    "prisma.config.ts"
  ],
  "ts-node": {
    "files": true,
    "esm": false
  }
}